{
  "meta": {
    "schema_version": "1.0",
    "last_updated": "2026-02-28",
    "data_type": "communications",
    "note": "Communication data should be loaded from PKG at runtime. This file provides the schema structure only."
  },
  "channels": {
    "messages": {
      "primary_use": "personal and casual professional",
      "response_expectations": {
        "tier_1_contacts": "immediate when available (from PKG relationships)",
        "inner_circle": "within 1 hour",
        "others": "same day"
      }
    },
    "email": {
      "primary_use": "professional, academic",
      "response_expectations": {
        "advisor": "within 24 hours",
        "clients": "within 24 hours",
        "others": "2-3 days"
      }
    },
    "calls": {
      "preference": "scheduled, not spontaneous",
      "exceptions": ["tier_1_contacts (from PKG)", "family_emergency"]
    }
  },
  "notification_preferences": {
    "always_immediate": ["tier_1_contacts (from PKG)", "calendar_reminders", "meeting_starting"],
    "batched": ["email", "social_media", "news", "non_urgent_messages"],
    "silenced_during_focus": ["social_notifications", "promotional", "news_alerts"],
    "never_silence": ["tier_1_contacts (from PKG)", "calendar_alerts", "genuine_emergencies"]
  },
  "triage_rules": {
    "immediate_surface": [
      {
        "condition": "from tier_1_contact (from PKG relationships)",
        "reason": "inner circle, always accessible"
      },
      {
        "condition": "contains 'urgent' from known contacts",
        "reason": "explicit urgency signal"
      }
    ],
    "batch_for_later": [
      {
        "condition": "promotional email",
        "reason": "never urgent"
      },
      {
        "condition": "social media notification",
        "reason": "distraction risk outweighs value"
      }
    ]
  }
}
